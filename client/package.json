    "build": "expo export --platform ios --output-dir dist-ios"
  },
  "dependencies": {
    "expo": "^52.0.0",
    "expo-image-picker": "~16.0.5",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-google-mobile-ads": "^16.0.3"
  }
}
